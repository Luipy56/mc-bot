# Minecraft server (required)
MC_HOST=
MC_PORT=25570
MC_USERNAME=
MC_VERSION=1.21.11
MC_AUTH=offline

# Server login command sent on spawn (e.g. /login yourpassword). Leave empty to skip.
MC_LOGIN_CMD=

# Viewer (npm start): first-person=1, third-person=0. Port for 3D view.
VIEWER_ENABLED=1
VIEWER_PORT=3000
# VIEWER_PERSPECTIVE=first

# Optional: run full browser client (mineflayer in browser). Port 8080 by default.
# npm run web-client  ->  http://localhost:8080
# WEB_CLIENT_PORT=8080

# Optional: SSH host for !pr command
PR_SSH_HOST=
