# Minecraft server — use NAME/SERVER_IP or MC_* (NAME/SERVER_IP take precedence)
NAME=
SERVER_IP=
PORT=25565
VERSION=latest

# Alternative names (used if NAME/SERVER_IP not set)
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=
MC_VERSION=1.21.11
MC_AUTH=offline

# Optional: account password for Mojang / Microsoft auth (mineflayer createBot password)
# MC_PASSWORD=

# Servers with AuthMe-style login: command sent on first spawn (same as viewer bot). Do not commit secrets.
# MC_LOGIN_CMD=/login yourpassword
# Alternative to MC_LOGIN_CMD: password used to build /login and /register commands automatically
# MC_AUTH_PASSWORD=
# Enable auto auth command handling from server messages (default true)
# MC_AUTO_AUTH=true
# Allow /register if server asks for it (default false)
# MC_AUTO_REGISTER=false
# Retry limits/cooldown for auth commands
# MC_MAX_LOGIN_ATTEMPTS=4
# MC_MAX_REGISTER_ATTEMPTS=2
# AUTH_CMD_COOLDOWN_MS=4000
# Ms to wait after MC_LOGIN_CMD before public spawn chat (default 600)
# MC_LOGIN_CHAT_DELAY_MS=600

# Override the first public chat line after spawn (default: "0/")
# MC_SPAWN_CHAT=
# Base delay before first public spawn chat when no login command is sent
# MC_SPAWN_CHAT_DELAY_MS=1600
# Human-like pacing/idle actions
# PLAYER_THINK_MIN_MS=350
# PLAYER_THINK_MAX_MS=1100
# HUMAN_ACTION_MIN_MS=18000
# HUMAN_ACTION_MAX_MS=36000
# Allow pathfinder to tower up by placing blocks under feet (default false; more human-like to keep off)
# ALLOW_1BY1_TOWERS=false
# Distance from spawn (blocks) after which protected-mode is cleared and digging is re-enabled
# PROTECTED_ZONE_CLEAR_DIST=80

# Comma-separated list of bot usernames to greet and respond to (e.g. BOT_FRIENDS=Jarvys,Jarvys2)
# BOT_FRIENDS=

# Optional: SSH host for !pr command
PR_SSH_HOST=

# Optional: max ms per task (default 120000); task fails with "timed out" after this
# TASK_TIMEOUT_MS=120000
# Per-block pathfinding timeout in mining (avoids pathfinder hang on unreachable blocks; default 25000)
# MINING_GOTO_TIMEOUT_MS=25000
# Tree mining tuning: avoid trying unreachable top logs (dy from bot), and how close to stand when chopping logs
# LOG_VERTICAL_DELTA=4
# LOG_GOAL_RADIUS=2

# Diamond cave mining (collect_diamond_ore uses diamondCave.js)
# DIAMOND_CAVE_SEARCH_DIST=96
# DIAMOND_CAVE_TARGET_Y=-32
# DIAMOND_CAVE_NEED_DESCENT_ABOVE_Y=48

# Wooden house (build_wooden_house): planks needed (default 112) and per-block place timeout (ms)
# HOUSE_PLANKS_NEEDED=112
# HOUSE_PLACE_TIMEOUT_MS=18000
# Preferred plank type for house objective (e.g. birch_planks, oak_planks)
# HOUSE_PLANK_NAME=birch_planks
# If true, craft_house_planks fails unless preferred plank can be crafted
# HOUSE_PLANK_STRICT=true
# Optional: explicit log target for house material gather (default derived from HOUSE_PLANKS_NEEDED)
# HOUSE_LOG_TARGET=30
# House footprint tuning (defaults: 6x6, wall height 2)
# HOUSE_WIDTH=6
# HOUSE_DEPTH=6
# HOUSE_WALL_HEIGHT=2

# Optional: override first pathfind target (default: spawn position stored on connect)
# GOTO_TEST_X=0
# GOTO_TEST_Y=64
# GOTO_TEST_Z=0

# Brain / retries (optional)
# TASK_MAX_FAILURES=4
# TASK_COOLDOWN_MS=45000
# STUCK_FAILURES_BEFORE_EXPLORE=2
# Starter wood target for first phase (default 3 logs)
# START_WOOD_TARGET=3
# Ms to wait after a failed task before next iteration (default 2500). Set 0 to retry immediately.
# TASK_FAIL_RETRY_MS=2500
# Hunt passive mobs when food is below this and inventory has no edible items (default 11)
# HUNT_WHEN_NO_FOOD_BELOW=11
# One-time starter hunt threshold if passive mobs are nearby (default 20)
# HUNT_STARTER_BELOW=20
# Hunting behavior tuning
# HUNT_TIMEOUT_MS=30000
# HUNT_ATTACK_INTERVAL_MS=700
# HUNT_PICKUP_WAIT_MS=1800
# Optional: use /rtp when stuck searching birch logs or passive food
# BIRCH_HOUSE_USE_RTP=true
# RTP_SEARCH_COOLDOWN_MS=180000

# Dragon combat can exceed 120s — raise for End fight (e.g. 300000 = 5 min)
# TASK_TIMEOUT_MS=300000
