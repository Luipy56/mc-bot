# Minecraft server — use NAME/SERVER_IP or MC_* (NAME/SERVER_IP take precedence)
NAME=
SERVER_IP=
PORT=25565
VERSION=latest

# Alternative names (used if NAME/SERVER_IP not set)
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=
MC_VERSION=1.21.11
MC_AUTH=offline

# Comma-separated list of bot usernames to greet and respond to (e.g. BOT_FRIENDS=Jarvys,Jarvys2)
# BOT_FRIENDS=

# Optional: SSH host for !pr command
PR_SSH_HOST=

# Optional: max ms per task (default 120000); task fails with "timed out" after this
# TASK_TIMEOUT_MS=120000
# Per-block pathfinding timeout in mining (avoids pathfinder hang on unreachable blocks; default 25000)
# MINING_GOTO_TIMEOUT_MS=25000

# Diamond cave mining (collect_diamond_ore uses diamondCave.js)
# DIAMOND_CAVE_SEARCH_DIST=96
# DIAMOND_CAVE_TARGET_Y=-32
# DIAMOND_CAVE_NEED_DESCENT_ABOVE_Y=48

# Wooden house (build_wooden_house): planks needed (default 112) and per-block place timeout (ms)
# HOUSE_PLANKS_NEEDED=112
# HOUSE_PLACE_TIMEOUT_MS=18000

# Optional: override first pathfind target (default: spawn position stored on connect)
# GOTO_TEST_X=0
# GOTO_TEST_Y=64
# GOTO_TEST_Z=0

# Brain / retries (optional)
# TASK_MAX_FAILURES=4
# TASK_COOLDOWN_MS=45000
# STUCK_FAILURES_BEFORE_EXPLORE=2
# Ms to wait after a failed task before next iteration (default 2500). Set 0 to retry immediately.
# TASK_FAIL_RETRY_MS=2500

# Dragon combat can exceed 120s — raise for End fight (e.g. 300000 = 5 min)
# TASK_TIMEOUT_MS=300000
